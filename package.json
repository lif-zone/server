{
  "name": "lif_server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "all": "node ./server.js",
    "fix-dns": "sudo chmod 777  /etc/resolv.conf && echo \"nameserver 8.8.8.8\" > /etc/resolv.conf",
    "all-dev": "DEV=1 node --inspect ./server.js",
    "dev": "sudo systemctl stop systemd-resolved && sudo chmod 777  /etc/resolv.conf && echo \"nameserver 127.0.0.1\" > /etc/resolv.conf && eslint . && npm run bundle && npm run all-dev",
    "bundle": "browserify pub/index.js > pub/bundle.js",
    "test": "mocha peer-relay/test.js --timeout 10000"
  },
  "dependencies": {
    "@babel/preset-env": "7.16.5",
    "@babel/preset-react": "7.16.5",
    "babelify": "10.0.0",
    "browserify": "17.0.0",
    "buffer": "6.0.3",
    "dns2": "2.0.1",
    "escape-string-regexp": "5.0.0",
    "events": "3.0.0",
    "express": "4.17.1",
    "inherits": "2.0.3",
    "iniparser": "1.0.5",
    "json-6": "1.1.4",
    "k-bucket": "5.1.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sdp-transform": "2.14.1",
    "simple-peer": "9.11.0",
    "through2": "^3.0.0",
    "util": "0.12.4",
    "uuid": "8.3.2",
    "ws": "8.3.0",
    "query-string": "7.0.1",
    "nconf": "0.11.3",
    "escape-html": "1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.16.5",
    "@babel/eslint-parser": "^7.16.5",
    "autoprefixer": "10.2.4",
    "babel-eslint": "10.1.0",
    "eslint": "^7.22.0",
    "eslint-plugin-react": "^7.27.1",
    "mocha": "9.1.3",
    "electron-webrtc": "0.3.0"
  },
  "browserify": {
    "transform": [
      [
        "babelify",
        {
          "presets": [
            "@babel/env",
            "@babel/react"
          ]
        }
      ]
    ]
  }
}
